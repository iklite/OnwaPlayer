<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:startColor="#CC8A1A"
                android:endColor="#A06010"
                android:angle="135"/>
            <stroke
                android:width="1.5dp"
                android:color="#FFD070"/>
        </shape>
    </item>

    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="oval">
            <gradient
                android:startColor="#F5A623"
                android:endColor="#D4881C"
                android:angle="135"/>
            <stroke
                android:width="2dp"
                android:color="#FFE0A0"/>
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#F5A623"
                android:endColor="#D4881C"
                android:angle="135"/>
            <stroke
                android:width="1dp"
                android:color="#FFCC60"/>
        </shape>
    </item>

</selector>
