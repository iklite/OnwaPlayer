<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item
        android:left="0dp"
        android:top="4dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#33004D30"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <!-- Main card -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#004D40"
                android:centerColor="#00695C"
                android:endColor="#00897B"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <!-- Subtle shine overlay at top -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#28FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"
                android:type="linear"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

</layer-list>
