<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_category_tag.xml
    ─────────────────────────────────────────────────────────
    Pill-shaped category badge background. API 1+.

    The radius is set to 999dp — a value large enough that Android
    always clips it to a perfect semicircle regardless of the view
    height, producing a true pill shape without needing to know the
    view's exact dimensions at design time.

    Colour palette:
      Fill   #EBF5FF — very light blue, barely tinted
      Border #90CAF9 — Material Blue 200, clearly readable
      Text   #0D47A1 — Material Blue 900 (set in the layout)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Near-white light-blue tint -->
    <solid android:color="#EBF5FF" />

    <!-- Large radius guarantees pill shape at any view height -->
    <corners android:radius="999dp" />

    <!-- Visible but soft border -->
    <stroke
        android:width="1dp"
        android:color="#90CAF9" />

</shape>
