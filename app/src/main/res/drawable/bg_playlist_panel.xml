<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer border glow (gold) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20F5A623"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Inner fill -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A1A2E"
                android:endColor="#12121F"
                android:angle="135"/>
            <corners android:radius="19dp"/>
        </shape>
    </item>

</layer-list>
