<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#30000000"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Main gradient with slight offset -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FFFFB74D"
                android:endColor="#FFFF5722"
                android:type="linear"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Inner shine (optional) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>
