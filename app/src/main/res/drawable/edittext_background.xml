<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Normal state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1AFFFFFF" /> <!-- Semi-transparent white -->
            <stroke 
                android:width="1dp" 
                android:color="#33FFFFFF" /> <!-- Light border -->
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>

    <!-- Focused state (when typing) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#2AFFFFFF" /> <!-- More opaque when focused -->
            <stroke 
                android:width="1.5dp" 
                android:color="@color/accent" /> <!-- Accent color border when focused -->
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>

</selector>
