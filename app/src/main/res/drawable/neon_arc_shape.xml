<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="ring"
    android:innerRadius="24dp"
    android:thickness="4dp"
    android:useLevel="false">

    <gradient
        android:startColor="#FF00FFFF"
        android:centerColor="#FF00AAFF"
        android:endColor="#00FFFFFF"
        android:type="sweep"
        android:centerX="0.5"
        android:centerY="0.5" />

    <stroke
        android:width="1dp"
        android:color="#AAFFFFFF" />

    <!-- Optional: outer glow effect via another layer? We'll do with a separate drawable for extra glow -->
</shape>
