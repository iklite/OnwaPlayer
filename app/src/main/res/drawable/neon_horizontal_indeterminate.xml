<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background track (dark semi-transparent) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <solid android:color="#33000000"/>
            <size android:height="6dp"/>
        </shape>
    </item>

    <!-- The moving neon bar (will be animated with an <animated-rotate> later) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp"/>
                <gradient
                    android:startColor="#FF00FFFF"
                    android:centerColor="#FF00AAFF"
                    android:endColor="#FF00FFFF"
                    android:angle="0"
                    android:centerX="0.5"
                    android:centerY="0.5"/>
                <stroke
                    android:width="1dp"
                    android:color="#AAFFFFFF"/>
                <size android:height="6dp"/>
            </shape>
        </clip>
    </item>
</layer-list>
