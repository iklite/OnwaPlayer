<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background (Gray Line) -->
    <item
        android:id="@android:id/background"
        android:top="8dp"
        android:bottom="8dp">
        <shape>
            <solid android:color="#20FFFFFF" /> <!-- Semi-transparent gray-white -->
            <size android:height="2dp" /> <!-- Thin horizontal line -->
        </shape>
    </item>

    <!-- Progress (White Line that fills) -->
    <item
        android:id="@android:id/progress"
        android:top="8dp"
        android:bottom="8dp">
        <clip>
            <shape>
                <solid android:color="#40FFFFFF" /> <!-- Semi-transparent white -->
                <size android:height="2dp" />
            </shape>
        </clip>
    </item>
</layer-list>
