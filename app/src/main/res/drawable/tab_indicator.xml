<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected tab -->
    <item android:state_selected="true" android:state_focused="false" android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_dark" />
            <padding android:bottom="2dp" />
        </shape>
    </item>

    <!-- Pressed tab -->
    <item android:state_selected="false" android:state_focused="false" android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_light" />
            <padding android:bottom="2dp" />
        </shape>
    </item>

    <!-- Default tab -->
    <item android:state_selected="false" android:state_focused="false" android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
