<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black"
    android:fitsSystemWindows="true">

    <!-- Custom Action Bar -->
    <LinearLayout 
		android:id="@+id/customActionBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/secondary"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Onwa Media Pro"
            android:textColor="@color/text_on_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

		<ImageButton
            android:id="@+id/btn_actionBar_searchView"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_search"
            android:background="@android:color/transparent"
            android:contentDescription="Search Songs" />
		
		<ImageButton
			android:id="@+id/btn_media_refresh"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:layout_margin="16dp"
			android:src="@drawable/ic_audio_refresh"
			android:background="@color/transparent"
			android:contentDescription="Refresh Media List" />
		
        <ImageButton
            android:id="@+id/btn_actionBar_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Main Content -->
    <FrameLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <HorizontalScrollView
		android:id="@+id/tabs_scroller"
		android:layout_width="match_parent" 
		android:layout_height="57dp" >
		
		<!-- Tab Bar -->
		<LinearLayout
			android:id="@+id/tab_container"
			android:layout_width="match_parent"
			android:layout_height="56dp"
			android:orientation="horizontal"
			android:background="@color/secondary"
			android:elevation="8dp">

			<!-- Audio Tab -->
			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:background="@drawable/tabs_background"
				android:clickable="true"
				android:id="@+id/tab_audio">

				<ImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/tab_audio_selector"
					/>

				<TextView
					android:id="@+id/tab_audio_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Music"
					android:textSize="10sp"
					android:textColor="@android:color/white"
					android:layout_marginTop="2dp" />
			</LinearLayout>

			<!-- Video Tab -->
			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:background="@drawable/tabs_background"
				android:clickable="true"
				android:id="@+id/tab_video">

				<ImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/tab_video_player"
					 />

				<TextView
					android:id="@+id/tab_video_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Videos"
					android:textSize="10sp"
					android:textColor="@android:color/white"
					android:layout_marginTop="2dp" />
			</LinearLayout>

			<!-- Photos Tab -->
			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:background="@drawable/tabs_background"
				android:clickable="true"
				android:id="@+id/tab_photos">

				<ImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/tab_photos_gallery"
					 />

				<TextView
					android:id="@+id/tab_photos_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Pictures"
					android:textSize="10sp"
					android:textColor="@android:color/white"
					android:layout_marginTop="2dp" />
			</LinearLayout>

			<!-- Sharing Tab -->
			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:background="@drawable/tabs_background"
				android:clickable="true"
				android:id="@+id/tab_share">

				<ImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/tab_p2p_share"
					 />

				<TextView
					android:id="@+id/tab_share_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Share"
					android:textSize="10sp"
					android:textColor="@android:color/white"
					android:layout_marginTop="2dp" />
			</LinearLayout>

			<!-- Settings Tab -->
			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:background="@drawable/tabs_background"
				android:clickable="true"
				android:id="@+id/tab_settings">

				<ImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/ic_settings"
					 />

				<TextView
					android:id="@+id/tab_settings_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Settings"
					android:textSize="10sp"
					android:textColor="@android:color/white"
					android:layout_marginTop="2dp" />
			</LinearLayout>

		</LinearLayout>
		
	</HorizontalScrollView>

</LinearLayout>
