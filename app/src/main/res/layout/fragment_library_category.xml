<?xml version="1.0" encoding="utf-8"?>
<com.ikechi.studio.onwa.widgets.MultiPanelLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/library_multi_panel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:dockStyle="stacked"
    app:lockInLandscape="false"
    app:hideDockedInLandscape="false">

    <!-- TOP VIEW — Categories -->
    <LinearLayout
        android:id="@+id/top_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#121212">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/libTopTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BROWSE"
                android:textColor="#F5A623"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/audio_refresh_progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminate="true"
                android:visibility="gone" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/category_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- PANEL — Playlists (dockable) -->
    <LinearLayout
        android:id="@+id/panel_playlists"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_playlist_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:background="@drawable/handle_playlist"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYLISTS"
                    android:textColor="#F5A623"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.18" />

                <TextView
                    android:id="@+id/tv_playlist_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 playlists"
                    android:textColor="#AAFFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_add_playlist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_add_playlist"
                android:src="@android:drawable/ic_input_add"
                android:scaleType="centerInside"
                android:contentDescription="Add new playlist" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/layout_playlist_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:visibility="visible">

                    <ImageView
                        android:id="@+id/btn_add_playlist_centered"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_add"
                        android:scaleType="fitCenter"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No playlists yet"
                        android:textColor="#50A0B0C8"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap + to create one"
                        android:textColor="#30A0B0C8"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/playlist_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</com.ikechi.studio.onwa.widgets.MultiPanelLayout>