<?xml version="1.0" encoding="utf-8"?>
<!--
item_audio_row.xml
────────────────────
List item for the AudioItem.

Columns:
[  play btn  |  title + artist • album  |  favorite + more options  |  duration  ]

Green/emerald accent.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:id="@+id/item_container"
	android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
	android:minHeight="64dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Play icon / button -->
    <TextView
        android:id="@+id/btn_audio_play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="&#9654;"
        android:textColor="#69F0AE"
        android:textSize="18sp"
        android:gravity="center"
        android:background="#1A69F0AE" />

    <!-- Title + Artist -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

	<LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.4"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

	    <LinearLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginEnd="4dp"
			android:layout_marginRight="4dp">
		
			<!-- Favorite Button -->
			<ImageButton
				android:id="@+id/audio_item_favorite"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:src="@drawable/ic_favorite_border"
				android:background="?android:attr/selectableItemBackgroundBorderless"
				android:contentDescription="Favorite"
				android:padding="4dp"/>
			
			<!-- More Options Button -->
			<ImageButton
				android:id="@+id/options_more"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:src="@drawable/ic_more_vert_white"
				android:layout_alignParentEnd="true"
				android:layout_alignParentRight="true"
				android:layout_marginRight="1dp"
				android:layout_marginEnd="1dp"
				android:background="?android:attr/selectableItemBackgroundBorderless"
				android:contentDescription="More options"
				android:padding="4dp"/>
		</LinearLayout>
		
        <!-- Duration -->
        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:paddingStart="4dp" />
    </LinearLayout>
</LinearLayout>
