<?xml version="1.0" encoding="utf-8"?>
<!--
  item_chat_message.xml
  ─────────────────────
  Updated chat list item.

  Additions over the original:
  • tv_private_badge — shown for @mention private messages.
    Displays "▶ Private to @username" (sender side) or
    "◀ Private from @username" (recipient side).
    Managed by ChatAdapter; GONE for broadcast messages.
  • Background is transparent by default; the adapter sets a
    translucent purple tint for private messages at bind time.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Private message badge (hidden for broadcasts) -->
    <TextView
        android:id="@+id/tv_private_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CE93D8"
        android:textSize="11sp"
        android:textStyle="italic"
        android:layout_marginBottom="2dp"
        android:visibility="gone" />

    <!-- Sender label -->
    <TextView
        android:id="@+id/tv_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="13sp"
        android:ellipsize="end"
        android:singleLine="true" />

    <!-- Message body -->
    <TextView
        android:id="@+id/tv_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="#E0E0E0"
        android:layout_marginTop="2dp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#66FFFFFF"
        android:layout_marginTop="2dp" />

</LinearLayout>
