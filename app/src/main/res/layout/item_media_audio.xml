<?xml version="1.0" encoding="utf-8"?>
<!--
  item_media_audio.xml
  ────────────────────
  List item for the Audio panel.

  Columns:
  [  play btn  |  title + artist • album  |  duration  ]

  Green/emerald accent to match handle_audio.xml.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Play icon / button -->
    <TextView
        android:id="@+id/btn_media_play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="&#9654;"
        android:textColor="#69F0AE"
        android:textSize="18sp"
        android:gravity="center"
        android:background="#1A69F0AE" />

    <!-- Title + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_media_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_media_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Duration -->
    <TextView
        android:id="@+id/tv_media_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:paddingStart="4dp" />

</LinearLayout>
